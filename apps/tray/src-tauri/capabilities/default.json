{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "moneysiren-local-desktop",
  "description": "Local MoneySiren desktop windows can drag, minimize, close, and toggle always-on-top.",
  "remote": {
    "urls": [
      "http://127.0.0.1:*/*",
      "http://localhost:*/*"
    ]
  },
  "windows": ["main", "moneysiren-hud"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-is-always-on-top",
    "core:window:allow-minimize",
    "core:window:allow-set-always-on-top",
    "core:window:allow-start-dragging"
  ]
}
