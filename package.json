{
  "name": "stackspend",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "node tools/scripts/run-web-with-tray.mjs",
    "dev:web": "node tools/scripts/run-pnpm.mjs --filter @stackspend/web dev",
    "dev:tray": "node tools/scripts/run-pnpm.mjs --filter @stackspend/tray tauri:dev",
    "build": "node tools/scripts/run-pnpm.mjs --workspace-script build",
    "build:native": "node tools/scripts/run-pnpm.mjs --filter @stackspend/tray tauri:build:unsigned",
    "build:local": "npm run build && npm run build:native",
    "start": "node tools/scripts/run-web-with-tray.mjs --web-script start --tray-mode built",
    "start:web": "node tools/scripts/run-pnpm.mjs --filter @stackspend/web start",
    "start:tray": "node tools/scripts/run-web-with-tray.mjs --skip-web --tray-mode built",
    "test": "node tools/scripts/run-pnpm.mjs --workspace-script test",
    "typecheck": "node tools/scripts/run-pnpm.mjs --workspace-script typecheck",
    "lint": "node tools/scripts/run-pnpm.mjs --workspace-script lint",
    "secret:scan": "node tools/scripts/secret-scan.mjs",
    "tray:native:check": "node tools/scripts/check-tray-native.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "tsx": "^4.21.0"
  }
}
