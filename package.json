{
  "name": "moneysiren-workspace",
  "version": "0.1.5",
  "description": "Local-first AI/cloud/SaaS usage and cost observability dashboard for open-source maintainers.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/ztwz11/moneysiren#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ztwz11/moneysiren.git"
  },
  "bugs": {
    "url": "https://github.com/ztwz11/moneysiren/issues"
  },
  "keywords": [
    "openai",
    "codex",
    "aws",
    "cloud-cost",
    "usage-dashboard",
    "cost-observability",
    "local-first",
    "developer-tools",
    "saas",
    "billing",
    "ai-agents",
    "sqlite"
  ],
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "node tools/scripts/run-web-with-tray.mjs",
    "dev:web": "node tools/scripts/run-pnpm.mjs --filter @moneysiren/web dev",
    "dev:tray": "node tools/scripts/run-pnpm.mjs --filter @moneysiren/tray tauri:dev",
    "dev:hud": "node tools/scripts/run-web-with-tray.mjs --desktop-mode hud",
    "build": "node tools/scripts/run-pnpm.mjs --workspace-script build",
    "build:native": "node tools/scripts/run-pnpm.mjs --filter @moneysiren/tray tauri:build:unsigned",
    "build:local": "npm run build && npm run build:native",
    "precompile": "node tools/scripts/ensure-precompiled.mjs --web",
    "prestart": "node tools/scripts/ensure-precompiled.mjs --web",
    "start": "node tools/scripts/run-web-with-tray.mjs --web-script start --tray-mode built",
    "prestart:web": "node tools/scripts/ensure-precompiled.mjs --web",
    "start:web": "node tools/scripts/run-pnpm.mjs --filter @moneysiren/web start",
    "start:tray": "node tools/scripts/run-web-with-tray.mjs --skip-web --tray-mode built",
    "prestart:hud": "node tools/scripts/ensure-precompiled.mjs --web",
    "start:hud": "node tools/scripts/run-web-with-tray.mjs --web-script start --tray-mode built --desktop-mode hud",
    "test": "node tools/scripts/run-pnpm.mjs --workspace-script test",
    "typecheck": "node tools/scripts/run-pnpm.mjs --workspace-script typecheck",
    "lint": "node tools/scripts/run-pnpm.mjs --workspace-script lint",
    "secret:scan": "node tools/scripts/secret-scan.mjs",
    "secret:scan:all": "node tools/scripts/secret-scan.mjs --history",
    "publish:cli:dry-run": "node tools/scripts/publish-cli.mjs",
    "publish:cli:latest": "node tools/scripts/publish-cli.mjs --publish",
    "publish:app:dry-run": "node tools/scripts/publish-app.mjs",
    "publish:app:latest": "node tools/scripts/publish-app.mjs --publish",
    "release:check": "node tools/scripts/check-release-readiness.mjs",
    "release:public": "node tools/scripts/release-public.mjs",
    "release:public:dry-run": "node tools/scripts/release-public.mjs --dry-run",
    "release:public:include-working-tree": "node tools/scripts/release-public.mjs --include-working-tree",
    "release:signing:encode-windows": "node tools/scripts/encode-windows-certificate.mjs",
    "release:signing:check": "node tools/scripts/check-signing-readiness.mjs",
    "release:web-runtime": "node tools/scripts/package-web-runtime.mjs",
    "release:desktop:signing-config": "node tools/scripts/prepare-tauri-signing-config.mjs",
    "tray:native:check": "node tools/scripts/check-tray-native.mjs",
    "release:metadata": "node tools/scripts/check-release-metadata.mjs",
    "test:release-metadata": "node --test tools/scripts/lib/release-metadata.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "tsx": "^4.21.0"
  }
}
