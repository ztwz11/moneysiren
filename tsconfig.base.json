{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@moneysiren/core": [
        "packages/core/src/index.ts"
      ],
      "@moneysiren/config": [
        "packages/config/src/index.ts"
      ],
      "@moneysiren/db": [
        "packages/db/src/index.ts"
      ],
      "@moneysiren/security": [
        "packages/security/src/index.ts"
      ],
      "@moneysiren/credentials": [
        "packages/credentials/src/index.ts"
      ],
      "@moneysiren/report": [
        "packages/report/src/index.ts"
      ],
      "@moneysiren/view-model": [
        "packages/view-model/src/index.ts"
      ],
      "@moneysiren/runtime": [
        "packages/runtime/src/index.ts"
      ],
      "@moneysiren/local-api": [
        "packages/local-api/src/index.ts"
      ],
      "@moneysiren/connector-mock": [
        "packages/connectors/mock/src/index.ts"
      ]
    }
  }
}
